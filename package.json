{
  "name": "repoguard",
  "version": "1.0.0",
  "description": "CLI tool to scan GitHub repos for trust scoring before cloning",
  "type": "module",
  "bin": {
    "repoguard": "./dist/bin/repoguard.js"
  },
  "scripts": {
